{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"${CLAUDE_PROJECT_DIR:-}\" ]; then exit 0; fi; AGENT_HOOKS_PROJECT_DIR=\"$CLAUDE_PROJECT_DIR\" python3 \"$CLAUDE_PROJECT_DIR/hooks/session-context.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"${CLAUDE_PROJECT_DIR:-}\" ]; then exit 0; fi; AGENT_HOOKS_PROJECT_DIR=\"$CLAUDE_PROJECT_DIR\" python3 \"$CLAUDE_PROJECT_DIR/hooks/prompt-router.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"${CLAUDE_PROJECT_DIR:-}\" ]; then exit 0; fi; AGENT_HOOKS_PROJECT_DIR=\"$CLAUDE_PROJECT_DIR\" python3 \"$CLAUDE_PROJECT_DIR/hooks/protect-paths.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"${CLAUDE_PROJECT_DIR:-}\" ]; then exit 0; fi; AGENT_HOOKS_PROJECT_DIR=\"$CLAUDE_PROJECT_DIR\" python3 \"$CLAUDE_PROJECT_DIR/hooks/command-policy.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"${CLAUDE_PROJECT_DIR:-}\" ]; then exit 0; fi; AGENT_HOOKS_PROJECT_DIR=\"$CLAUDE_PROJECT_DIR\" python3 \"$CLAUDE_PROJECT_DIR/hooks/quality-gate.py\"",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"${CLAUDE_PROJECT_DIR:-}\" ]; then exit 0; fi; AGENT_HOOKS_PROJECT_DIR=\"$CLAUDE_PROJECT_DIR\" python3 \"$CLAUDE_PROJECT_DIR/hooks/stop-if-quality-failed.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"${CLAUDE_PROJECT_DIR:-}\" ]; then exit 0; fi; AGENT_HOOKS_PROJECT_DIR=\"$CLAUDE_PROJECT_DIR\" python3 \"$CLAUDE_PROJECT_DIR/hooks/session-end-audit.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
